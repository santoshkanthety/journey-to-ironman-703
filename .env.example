# Copy to ~/.ironman.env (or .env, gitignored), fill in, then `source` it.

# --- Postgres (local) ---
# Any Postgres 14+ works. The `ironman` schema is created by schema_pg.sql.
export IRONMAN_DB_URL=postgresql://user:password@localhost:5432/fitness

# --- Strava API (https://www.strava.com/settings/api) ---
# Get a refresh token with activity:read_all scope via etl/strava_auth.py
export STRAVA_CLIENT_ID=
export STRAVA_CLIENT_SECRET=
export STRAVA_REFRESH_TOKEN=

# --- Databricks (optional — cloud dashboard) ---
# Authenticate the CLI first: databricks auth login --host <workspace-url>
export DATABRICKS_WAREHOUSE_ID=
export DATABRICKS_CATALOG=workspace
export DATABRICKS_HOST=
